@model Job_Portal_System.ViewModel.JobDetailsViewModel

@{
    ViewBag.Title = "Job Details";
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";

    var userId = Session["UserId"] != null ? (int)Session["UserId"] : 0;
    var hasApplied = ViewBag.HasApplied != null && (bool)ViewBag.HasApplied;

    var job = Model.Job;
    var company = job.EMPLOYER.company_name ?? Model.Employerr_detail.company_name ?? "";
    var postedDate = job.posted_date.HasValue == true ? job.posted_date.Value.ToString("dd MMM yyyy") : "";
    var salary = job.salary_range ?? "—";
    var jtype = job.job_type ?? "—";
    var location = job.location ?? "—";
    var detailsUrl = Url.Action("JobDetails", "Job", new { id = job.job_id });
    var saveFallback = Url.Action("Create", "SavedJobs", new { job_id = job.job_id });
}

<div class="hh-card" style="max-width:1100px; margin:20px auto; padding:18px;">
    <div class="hh-page-header" style="margin-bottom:14px;">
        <h1 style="margin:0;">@job.job_title</h1>
        <p class="subtitle" style="margin-top:6px;">@company &nbsp;·&nbsp; @location</p>
    </div>

    <div style="display:grid; grid-template-columns: 2fr 360px; gap:18px; align-items:start;">
        <!-- Left: Job content -->
        <main class="hh-card" style="padding:16px;">
            <div style="display:flex; gap:12px; align-items:flex-start;">
                <div style="width:64px; height:64px; border-radius:10px; background:linear-gradient(135deg,var(--blue-light),var(--blue)); color:#fff; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">
                    <i class="fa-solid fa-briefcase"></i>
                </div>

                <div style="flex:1; min-width:0;">
                    <div style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start;">
                        <div style="min-width:0;">
                            <div style="font-weight:700; font-size:18px; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@job.job_title</div>
                            <div style="color:var(--text-muted); font-size:13px; margin-top:6px;">Posted: @postedDate</div>
                        </div>

                        <div style="text-align:right;">
                            <div style="display:flex; gap:8px; justify-content:flex-end; align-items:center;">
                                <span class="hh-badge hh-badge-gray">@jtype</span>
                                <span class="hh-badge hh-badge-blue">@salary</span>
                            </div>
                        </div>
                    </div>

                    <!-- short summary -->
                    <div style="margin-top:12px; color:var(--text-second); font-size:14px; line-height:1.45;">
                        @((job.job_description ?? "").Length > 300 ? ((job.job_description ?? "").Substring(0, 297) + "...") : (job.job_description ?? ""))
                    </div>
                </div>
            </div>

            <div class="hh-divider" style="margin:16px 0;"></div>

            <!-- Requirements & Responsibilities -->
            <section>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <h3 class="hh-card-title" style="margin:0;">Role & Requirements</h3>
                    <button id="toggleReq" class="hh-btn hh-btn-outline hh-btn-sm" type="button"><i class="fa-solid fa-chevron-down"></i> Toggle</button>
                </div>

                <div id="reqBlock" style="margin-top:12px; color:var(--text-second);">
                    @if (!string.IsNullOrWhiteSpace(Model.Job.requirements))
                    {
                        <div style="margin-bottom:8px;"><strong>Requirements:</strong></div>
                        <div style="white-space:pre-wrap;">@Model.Job.requirements</div>
                    }
                    @*@if (!string.IsNullOrWhiteSpace(Model.Job.responsibilities))
                    {
                        <div style="margin-top:12px;"><strong>Responsibilities:</strong></div>
                        <div style="white-space:pre-wrap;">@Model.Job.responsibilities</div>
                    }*@
                </div>
            </section>

            <div class="hh-divider"></div>

            <!-- Skills / Tags -->
            <section>
                <h4 class="hh-card-title" style="margin:0 0 8px 0;">Skills & Tags</h4>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    @if (Model.Skills != null && Model.Skills.Any())
                    {
                        foreach (var s in Model.Skills)
                        {
                            <span class="hh-badge hh-badge-gray" style="padding:6px 10px; font-weight:600;">@s</span>
                        }
                    }
                    else
                    {
                        <span class="hh-badge hh-badge-gray">No tags</span>
                    }
                </div>
            </section>

            <div class="hh-divider"></div>

            <!-- Apply flow & extra actions -->
            <div style="display:flex; gap:10px; align-items:center; margin-top:8px; flex-wrap:wrap;">
                @if (userId == 0)
                {
                    <a href="@Url.Action("Login", "Account")" class="hh-btn hh-btn-primary"><i class="fa-solid fa-right-to-bracket"></i> Login to Apply</a>
                }
                else if (hasApplied)
                {
                    <button class="hh-btn hh-btn-outline" disabled><i class="fa-solid fa-circle-check"></i> Already Applied</button>
                    <a href="@Url.Action("ApplicationStatus", "Application", new { jobId = job.job_id })" class="hh-btn hh-btn-ghost">View Application</a>
                }
                else
                {
                    <a href="@Url.Action("Apply", "Application", new { jobId = job.job_id })" id="applyNow" class="hh-btn hh-btn-primary"><i class="fa-solid fa-paper-plane"></i> Apply Now</a>
                }

                <button type="button" class="hh-btn hh-btn-ghost btn-save-job" data-jobid="@job?.job_id" data-fallback="@saveFallback"><i class="fa-solid fa-bookmark"></i> Save</button>

                <a href="@Url.Action("Index","Chat", new { receiverId = job.EMPLOYER.employer_id })" class="hh-btn hh-btn-outline"><i class="fa-solid fa-envelope"></i> Message Employer</a>

                <button type="button" id="btnShare" class="hh-btn hh-btn-sm hh-btn-outline"><i class="fa-solid fa-link"></i> Copy Link</button>
            </div>
        </main>

        <!-- Right: Employer card -->
        <aside class="hh-card" style="padding:14px;">
            <div style="text-align:center;">
                <div style="width:86px; height:86px; margin:0 auto 10px; border-radius:12px; overflow:hidden; display:flex; align-items:center; justify-content:center; background:var(--bg);">
                    @Html.Raw(Model.Employerr_detail.companyLogo ?? "<i class='fa-solid fa-building' style='font-size:32px;color:var(--text-muted);'></i>")
                </div>

                <div style="font-weight:700; color:var(--text-primary); font-size:16px;">@company</div>
                <div style="color:var(--text-muted); font-size:13px; margin-top:6px;">@Model.Employer.email</div>

                <div style="margin-top:12px;">
                    <a href="@Url.Action("EmployerProfile","Employeer", new { id = job.EMPLOYER.employer_id })" class="hh-btn hh-btn-outline hh-btn-sm" style="display:inline-flex; gap:8px;"><i class="fa-solid fa-building"></i> View Company</a>
                </div>

                <div style="margin-top:12px; display:flex; gap:8px; justify-content:center;">
                    <span class="hh-badge hh-badge-blue">Verified</span>
                    <span class="hh-badge hh-badge-gray">@jtype</span>
                </div>

                <div class="hh-divider" style="margin:14px 0;"></div>

                <div style="text-align:left; color:var(--text-muted); font-size:13px;">
                    <div><strong>Location</strong></div>
                    <div>@location</div>
                    <div style="margin-top:8px;"><strong>Posted</strong></div>
                    <div>@postedDate</div>
                </div>
            </div>
        </aside>
    </div>
</div>

<style>
    /* view-specific tweaks; main theme lives in Content/HireHub.DarkBlue.css */
    .job-subtitle { color:var(--text-muted); }
    #reqBlock { transition: max-height .18s ease, opacity .18s ease; overflow: hidden; }
    #reqBlock.collapsed { max-height: 0; opacity: 0; padding: 0; margin: 0; }
    #reqBlock.expanded { max-height: 2000px; opacity: 1; }

    @@media (max-width:920px) {
        div[style*="grid-template-columns: 2fr 360px"] { grid-template-columns: 1fr; }
    }
</style>

@section scripts {
    <script>
    (function ($) {
        function toast(msg, type) {
            var $t = $('<div class="hh-alert" style="position:fixed; top:90px; right:18px; z-index:1400;"></div>');
            $t.addClass(type === 'error' ? 'hh-alert-danger' : 'hh-alert-success');
            $t.html('<i class="fa-solid fa-circle-info"></i><div style="margin-left:8px;">' + msg + '</div>');
            $('body').append($t);
            setTimeout(function () { $t.fadeOut(300, function () { $t.remove(); }); }, 2000);
        }

        // Toggle requirements
        var $req = $('#reqBlock');
        $req.addClass('expanded');
        $('#toggleReq').on('click', function () {
            $req.toggleClass('collapsed expanded');
            var $btn = $(this);
            $btn.find('i').toggleClass('fa-chevron-down fa-chevron-up');
        });

        // Copy job link
        $('#btnShare').on('click', function () {
            var url = window.location.href;
            navigator.clipboard?.writeText(url).then(function () {
                toast('Link copied to clipboard', 'success');
            }).catch(function () {
                // fallback
                var $temp = $('<input>');
                $('body').append($temp);
                $temp.val(url).select();
                document.execCommand('copy');
                $temp.remove();
                toast('Link copied to clipboard', 'success');
            });
        });

        // Save job via AJAX with fallback
        $('.btn-save-job').on('click', function () {
            var $btn = $(this);
            var jobId = $btn.data('jobid');
            var fallback = $btn.data('fallback');
            $btn.prop('disabled', true);
            $.post('@Url.Action("SaveJob","SavedJobs")', { jobId: jobId })
                .done(function (res) {
                    try {
                        if (res && (res.success === true || res.saved === true || res === true)) {
                            $btn.removeClass('hh-btn-ghost').addClass('hh-btn-success').html('<i class="fa-solid fa-check"></i> Saved');
                            toast('Job saved', 'success');
                            return;
                        }
                    } catch (e) {}
                    $btn.removeClass('hh-btn-ghost').addClass('hh-btn-success').html('<i class="fa-solid fa-check"></i> Saved');
                    toast('Job saved', 'success');
                })
                .fail(function () {
                    window.location = fallback;
                })
                .always(function () { $btn.prop('disabled', false); });
        });

        // Apply button small enhancement: show confirmation before leaving
        $('#applyNow').on('click', function (e) {
            // Let default navigation happen; optionally we could POST via AJAX if server supports it.
            // Add subtle UX: show loading state briefly
            var $a = $(this);
            $a.addClass('disabled');
            setTimeout(function () { $a.removeClass('disabled'); }, 1000);
        });
    })(jQuery);
    </script>
}