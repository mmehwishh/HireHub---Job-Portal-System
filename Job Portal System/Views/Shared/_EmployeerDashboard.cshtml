@{
    Layout = null;
    var initials = ViewBag.UserInitials as string ?? "";
    var userName = Session["UserName"] ?? "Employer";
    var unreadMessages = ViewBag.UnreadMessages ?? 0;
    var unreadNotifications = ViewBag.UnreadNotifications ?? 0;

    if (string.IsNullOrWhiteSpace(initials))
    {
        // derive initials from name
        var parts = ((userName.ToString()) ?? "").Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        initials = parts.Length == 0 ? "EMP" : (parts.Length == 1 ? parts[0].Substring(0, 1) : (parts[0].Substring(0, 1) + parts[1].Substring(0, 1))).ToUpper();
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Employer Dashboard</title>

    @RenderSection("styles", required: false)

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="~/Content/HireHub.DarkBlue.css" rel="stylesheet" />

    <style>
        .hh-logo {
            text-decoration: none;
        }

        .hh-content {
            transition: margin-left .18s ease;
        }

        .hh-search-inner {
            max-width: 520px;
        }

        .hh-sidebar a.hh-nav-link.active {
            box-shadow: none;
        }

        @@media (max-width:900px) {
            .hh-search {
                display: none;
            }
        }
    </style>
</head>
<body>
    <header class="hh-topbar" role="banner">
        <button class="hh-menu-toggle" id="menuToggle" aria-label="Toggle menu" aria-expanded="false">
            <i class="fa-solid fa-bars" aria-hidden="true"></i>
        </button>

        <a class="hh-logo" href="/Employeer/Dashboard" aria-label="HireHub home">
            <div class="hh-logo-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
                    <path d="M20 7h-4V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zm-10-2h4v2h-4V5zm2 11a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6-4H6v-1l2-2h8l2 2v1z" />
                </svg>
            </div>
            <span class="hh-logo-name">Hire<span>Hub</span></span>
        </a>

        @*<div class="hh-search" role="search">
            <form class="hh-search-inner" action="/Employeer/SearchCandidates" method="get">
                <i class="fa-solid fa-search" aria-hidden="true"></i>
                <input name="search" type="search" placeholder="Search candidates, skills, or resumes..." aria-label="Search" />
            </form>
        </div>*@

        <div class="hh-topbar-right" role="navigation">
            <a href="/Chat/Inbox" class="hh-icon-btn" title="Messages">
                <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                @if ((int)unreadMessages > 0)
                {<span class="badge-dot" aria-hidden="true"></span>}
            </a>

            <div class="hh-avatar-wrap" id="avatarWrap" tabindex="0">
                <div class="hh-avatar" id="avatarBtn" aria-haspopup="true" aria-expanded="false">@initials</div>

                <div class="hh-dropdown" id="avatarDropdown" role="menu">
                    <a href="/Employeer/MyProfile" role="menuitem"><i class="fa-solid fa-user"></i> Company Profile</a>
                    <a href="/Job/PostJob" role="menuitem"><i class="fa-solid fa-plus"></i> Post a Job</a>
                    <div class="hh-dropdown-divider"></div>
                    <a href="/Account/Logout" class="logout-link" role="menuitem"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="hh-overlay" id="sidebarOverlay" tabindex="-1"></div>

    <aside class="hh-sidebar" id="sidebar" role="navigation">
        <nav>
            <div class="hh-nav-section">
                <div class="hh-nav-label">Main</div>
                <a href="/Employeer/Dashboard" class="hh-nav-link"><i class="fa-solid fa-house"></i> Dashboard</a>
                <a href="/Employeer/MyProfile" class="hh-nav-link"><i class="fa-solid fa-building"></i> Company Profile</a>
            </div>

            <div class="hh-nav-section">
                <div class="hh-nav-label">Jobs & Hiring</div>
                <a href="/Job/PostJob" class="hh-nav-link"><i class="fa-solid fa-plus"></i> Post a Job</a>
                <a href="/Job/ManageJobs" class="hh-nav-link"><i class="fa-solid fa-clipboard-list"></i> Manage Jobs</a>
             </div>

            <div class="hh-nav-section">
                <div class="hh-nav-label">Communication</div>
                <a href="/Chat/Inbox" class="hh-nav-link"><i class="fa-solid fa-envelope"></i> Messages <span class="hh-nav-badge">@unreadMessages</span></a>
                <a href="/Notification/EmployeerNotifications" class="hh-nav-link"><i class="fa-solid fa-bell"></i> Notifications <span class="hh-nav-badge">@unreadMessages</span></a>

            </div>

            

        </nav>

        <div class="hh-sidebar-footer">
            <a href="/Employeer/MyProfile" class="hh-sidebar-profile">
                <div class="hh-sidebar-avatar">@initials</div>
                <div>
                    <div class="hh-sidebar-user-name">@userName</div>
                    <div class="hh-sidebar-user-role">Employer</div>
                </div>
            </a>
        </div>
    </aside>

    <main class="hh-content" role="main">
        <div class="container-fluid py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="hh-footer">
        &copy; @DateTime.Now.Year HireHub &nbsp;·&nbsp; Employer Portal
    </footer>

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            const avatarWrap = document.getElementById('avatarWrap');
            const avatarBtn = document.getElementById('avatarBtn');
            const menuToggle = document.getElementById('menuToggle');
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');

            // Toggle Avatar Dropdown
            avatarBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                avatarWrap.classList.toggle('open');
            });

            document.addEventListener('click', (e) => {
                if (!avatarWrap.contains(e.target)) avatarWrap.classList.remove('open');
            });

            // Mobile Sidebar Toggle
            menuToggle.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('open');
            });

            overlay.addEventListener('click', () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('open');
            });

            // Active Link Highlight
            const currentPath = window.location.pathname.toLowerCase();
            document.querySelectorAll('.hh-nav-link').forEach(link => {
                if (link.getAttribute('href').toLowerCase() === currentPath) {
                    link.classList.add('active');
                }
            });
        })();
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>