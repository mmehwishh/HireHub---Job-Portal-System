@{
    Layout = null;
    var initials = ViewBag.UserInitials as string ?? "";
    var userName = Session["UserName"] ?? "User";
    var unreadMessages = ViewBag.UnreadMessages ?? 0;
    var unreadNotifications = ViewBag.UnreadNotifications ?? 0;

    if (string.IsNullOrWhiteSpace(initials))
    {
        // derive initials from name (simple)
        // (string) laga kar computer ko batayein ke ye string hi hai
        var parts = ((userName.ToString()) ?? "").Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries); 
        initials = parts.Length == 0 ? "AS" : (parts.Length == 1 ? parts[0].Substring(0, 1) : (parts[0].Substring(0, 1) + parts[1].Substring(0, 1))).ToUpper();
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - HireHub</title>

    <!-- Fonts & icons -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Bootstrap (ensure consistent across app) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Shared HireHub theme -->
    <link href="~/Content/HireHub.DarkBlue.css" rel="stylesheet" />

    <style>
        /* Minimal per-layout tweaks */
        .hh-logo { text-decoration: none; }
        .hh-content { transition: margin-left .18s ease; }
        .hh-search-inner { max-width: 520px; }
        .hh-sidebar a.hh-nav-link.active { box-shadow: none; }
        /* compact mobile avatar menu adjustments */
        @@media (max-width:900px) {
            .hh-search { display:none; }
        }
    </style>
</head>
<body>
    <!-- TOPBAR -->
    <header class="hh-topbar" role="banner">
        <button class="hh-menu-toggle" id="menuToggle" aria-label="Toggle menu" aria-expanded="false">
            <i class="fa-solid fa-bars" aria-hidden="true"></i>
        </button>

        <a class="hh-logo" href="/JobSeeker/Dashboard" aria-label="HireHub home">
            <div class="hh-logo-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
                    <path d="M20 7h-4V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zm-10-2h4v2h-4V5zm2 11a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6-4H6v-1l2-2h8l2 2v1z" />
                </svg>
            </div>
            <span class="hh-logo-name">Hire<span>Hub</span></span>
        </a>

        <div class="hh-search" role="search">
            <form class="hh-search-inner" action="/Job/BrowseJobs" method="get" onsubmit="return true;">
                <i class="fa-solid fa-search" aria-hidden="true"></i>
                <input name="search" type="search" placeholder="Search jobs..." aria-label="Search jobs" />
            </form>
        </div>

        <div class="hh-topbar-right" role="navigation" aria-label="Topbar actions">
            <a href="/Chat/Inbox" class="hh-icon-btn" title="Messages" aria-label="Messages">
                <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                @if ((int)unreadMessages > 0)
                {
                    <span class="badge-dot" aria-hidden="true"></span>
                }
            </a>

            <a href="/Notification/JobSeekerNotifications" class="hh-icon-btn" title="Notifications" aria-label="Notifications">
                <i class="fa-solid fa-bell" aria-hidden="true"></i>
                @if ((int)unreadNotifications > 0)
                {
                    <span class="badge-dot" aria-hidden="true"></span>
                }
            </a>

            <div class="hh-avatar-wrap" id="avatarWrap" tabindex="0">
                <div class="hh-avatar" id="avatarBtn" aria-haspopup="true" aria-expanded="false">@initials</div>

                <div class="hh-dropdown" id="avatarDropdown" role="menu" aria-label="User menu">

                    <a href="/JobSeeker/ViewProfile" role="menuitem"><i class="fa-solid fa-user"></i> My Profile</a>
                    <a href="/JobSeeker/ViewProfile" role="menuitem"><i class="fa-solid fa-user"></i> My Profile</a>
                    <a href="/JobSeeker/ManageSkills" role="menuitem"><i class="fa-solid fa-screwdriver-wrench"></i> My Skills</a>
                    <a href="/SavedJobs/SavedJobsList" role="menuitem"><i class="fa-solid fa-bookmark"></i> Saved Jobs</a>
                    <div class="hh-dropdown-divider"></div>
                    <a href="/Account/Logout" class="logout-link" role="menuitem"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <!-- SIDEBAR OVERLAY (MOBILE) -->
    <div class="hh-overlay" id="sidebarOverlay" tabindex="-1"></div>

    <!-- SIDEBAR -->
    <aside class="hh-sidebar" id="sidebar" role="navigation" aria-label="Main menu">
        <nav>
            <div class="hh-nav-section">
                <div class="hh-nav-label">Account</div>
                <a href="/JobSeeker/Dashboard" class="hh-nav-link"><i class="fa-solid fa-user"></i> Dashboard</a>
                <a href="/JobSeeker/ViewProfile" class="hh-nav-link"><i class="fa-solid fa-user"></i> My Profile</a>
                <a href="/JobSeeker/ManageSkills" class="hh-nav-link"><i class="fa-solid fa-screwdriver-wrench"></i> My Skills</a>
            </div>

            <div class="hh-nav-section">
                <div class="hh-nav-label">Jobs</div>
                <a href="/Job/BrowseJobs" class="hh-nav-link"><i class="fa-solid fa-magnifying-glass"></i> Browse Jobs</a>
                <a href="/Job/DiscoverJobs" class="hh-nav-link"><i class="fa-solid fa-compass"></i> Discover</a>
                <a href="/SavedJobs/SavedJobsList" class="hh-nav-link"><i class="fa-solid fa-bookmark"></i> Saved Jobs</a>
                <a href="/Application/MyApplications" class="hh-nav-link"><i class="fa-solid fa-file-circle-check"></i> My Applications</a>
            </div>

            <div class="hh-nav-section">
                <div class="hh-nav-label">Communication</div>
                <a href="/Chat/Inbox" class="hh-nav-link"><i class="fa-solid fa-envelope"></i> Messages <span class="hh-nav-badge">@unreadMessages</span></a>
                <a href="/Notification/JobSeekerNotifications" class="hh-nav-link"><i class="fa-solid fa-bell"></i> Notifications <span class="hh-nav-badge red">@unreadNotifications</span></a>
            </div>
        </nav>

        <div class="hh-sidebar-footer">
            <a href="/JobSeeker/ViewProfile" class="hh-sidebar-profile">
                <div class="hh-sidebar-avatar">@initials</div>
                <div>
                    <div class="hh-sidebar-user-name">@userName</div>
                    <div class="hh-sidebar-user-role">Job Seeker</div>
                </div>
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="hh-content" role="main" aria-live="polite">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="hh-footer" role="contentinfo">
        &copy; @DateTime.Now.Year HireHub &nbsp;·&nbsp;
        <a href="#">Privacy</a> &nbsp;·&nbsp;
        <a href="#">Terms</a> &nbsp;·&nbsp;
        <a href="#">Help</a>
    </footer>

    @RenderSection("scripts", required: false)

    <!-- Scripts -->
    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            // Elements
            const avatarWrap = document.getElementById('avatarWrap');
            const avatarBtn = document.getElementById('avatarBtn');
            const avatarDropdown = document.getElementById('avatarDropdown');
            const menuToggle = document.getElementById('menuToggle');
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');

            // Accessibility helpers
            function closeAvatar() {
                avatarWrap.classList.remove('open');
                avatarBtn.setAttribute('aria-expanded', 'false');
            }
            function openAvatar() {
                avatarWrap.classList.add('open');
                avatarBtn.setAttribute('aria-expanded', 'true');
                avatarDropdown.querySelector('a')?.focus();
            }

            // Avatar toggle
            avatarBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                avatarWrap.classList.toggle('open');
                avatarBtn.setAttribute('aria-expanded', avatarWrap.classList.contains('open'));
            });

            avatarWrap.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeAvatar();
            });

            // Click outside to close
            document.addEventListener('click', function (e) {
                if (!avatarWrap.contains(e.target)) closeAvatar();
            });

            // Mobile sidebar
            function openSidebar() {
                sidebar.classList.add('open');
                overlay.classList.add('open');
                menuToggle.setAttribute('aria-expanded', 'true');
            }
            function closeSidebar() {
                sidebar.classList.remove('open');
                overlay.classList.remove('open');
                menuToggle.setAttribute('aria-expanded', 'false');
            }

            menuToggle.addEventListener('click', function (e) {
                if (sidebar.classList.contains('open')) closeSidebar(); else openSidebar();
            });
            overlay.addEventListener('click', closeSidebar);

            // Active nav link highlight
            const currentPath = window.location.pathname.toLowerCase();
            document.querySelectorAll('.hh-nav-link').forEach(function (link) {
                const href = (link.getAttribute('href') || '').toLowerCase();
                if (href && currentPath.startsWith(href)) {
                    link.classList.add('active');
                }
            });

            // keyboard: open sidebar with Ctrl+M (helpful)
            document.addEventListener('keydown', function (e) {
                if (e.ctrlKey && e.key.toLowerCase() === 'm') {
                    e.preventDefault();
                    if (sidebar.classList.contains('open')) closeSidebar(); else openSidebar();
                }
            });

            // Touch: improve click area for small buttons
            document.querySelectorAll('.hh-icon-btn, .hh-menu-toggle, .hh-avatar').forEach(function (el) {
                el.addEventListener('touchstart', function () { }, { passive: true });
            });
        })();
    </script>
</body>
</html>