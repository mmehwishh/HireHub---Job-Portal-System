@model IEnumerable<Job_Portal_System.ViewModel.JobSeekerApplicationViewModel>

@{
    ViewBag.Title = "My Applications";
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";

    Func<dynamic, string> StatusBadgeClass = (s) =>
    {
        var st = (s.Status ?? "").ToString().ToLowerInvariant();
        if (st.Contains("approved") || st.Contains("accepted") || st.Contains("hired")) return "hh-badge hh-badge-green";
        if (st.Contains("interview") || st.Contains("scheduled")) return "hh-badge hh-badge-blue";
        if (st.Contains("rejected") || st.Contains("declined")) return "hh-badge hh-badge-red";
        if (st.Contains("pending")) return "hh-badge hh-badge-amber";
        return "hh-badge hh-badge-gray";
    };
}

<div class="hh-card" style="max-width:980px; margin:20px auto; padding:18px;">
    <div class="hh-page-header">
        <h1>My Applications</h1>
        <p class="subtitle">Track your applications, interview details and employer feedback — withdraw or message employers as needed.</p>
    </div>

    <div style="margin-top:14px; display:grid; gap:12px;">
        @if (Model == null || !Model.Any())
        {
            <div class="hh-empty" style="padding:36px;">
                <div class="hh-empty-icon"><i class="fa-solid fa-briefcase"></i></div>
                <h3>No applications yet</h3>
                <p class="subtitle">Apply to jobs and they will appear here with status and actions.</p>
            </div>
        }
        else
        {
            foreach (var app in Model)
            {
                var badgeClass = StatusBadgeClass(app);
                <div class="hh-card app-row" data-app-id="@app.ApplicationId" style="display:flex; gap:14px; align-items:flex-start; padding:14px;">
                    <div style="width:64px; height:64px; border-radius:12px; background:linear-gradient(135deg,var(--blue-light),var(--blue)); color:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:20px;">
                        <i class="fa-solid fa-briefcase"></i>
                    </div>

                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">
                            <div style="min-width:0;">
                                <div style="font-weight:700; color:var(--text-primary); font-size:16px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    @app.JobTitle
                                </div>
                                <div style="color:var(--text-muted); font-size:13px; margin-top:6px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    @app.CompanyName
                                </div>
                                <div style="color:var(--text-muted); font-size:13px; margin-top:6px;">
                                    Applied: @(app.AppliedDate.HasValue ? app.AppliedDate.Value.ToString("dd MMM yyyy") : "--")
                                </div>
                            </div>

                            <div style="text-align:right; display:flex; flex-direction:column; gap:8px; align-items:flex-end;">
                                <span class="@badgeClass" style="font-weight:700; padding:6px 10px;">@app.Status</span>

                                <div style="display:flex; gap:8px; margin-top:6px;">
                                    <a href="@Url.Action("JobDetails","Job", new { id = app.JobId })" class="hh-btn hh-btn-outline hh-btn-sm" title="View job">
                                        <i class="fa-solid fa-eye"></i> View
                                    </a>

                                    <a href="@Url.Action("Index","Chat", new { receiverId = app.EmployerId })" class="hh-btn hh-btn-primary hh-btn-sm" title="Message employer">
                                        <i class="fa-solid fa-envelope"></i> Message
                                    </a>

                                    @if (app.Status != null && app.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button type="button" class="hh-btn hh-btn-danger hh-btn-sm btn-withdraw" data-id="@app.ApplicationId">
                                            <i class="fa-solid fa-ban"></i> Withdraw
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        @* Interview block (shows only when present) *@
                        @if (app.Status != null && app.Status.IndexOf("Interview", StringComparison.OrdinalIgnoreCase) >= 0 && app.InterviewDate.HasValue)
                        {
                            <div style="margin-top:12px; background:var(--blue-pale); border-left:4px solid var(--blue); padding:12px; border-radius:8px;">
                                <div style="font-weight:700; color:var(--blue); margin-bottom:6px;"><i class="fa-solid fa-calendar-check"></i> Interview Details</div>
                                <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:8px; font-size:13px; color:var(--text-primary);">
                                    <div><strong>Date &amp; Time</strong><div>@app.InterviewDate.Value.ToString("dd MMM yyyy, hh:mm tt")</div></div>
                                    <div>
                                        <strong>Location / Link</strong>
                                        <div>
                                            @if (!string.IsNullOrEmpty(app.InterviewLocation) && app.InterviewLocation.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <a href="@app.InterviewLocation" target="_blank">Join meeting</a>
                                            }
                                            else
                                            {
                                                @(!string.IsNullOrEmpty(app.InterviewLocation) ? app.InterviewLocation : "—")
                                            }
                                        </div>
                                    </div>
                                    <div><strong>Notes</strong><div style="color:var(--text-muted);">@(string.IsNullOrEmpty(app.InterviewNotes) ? "No instructions." : app.InterviewNotes)</div></div>
                                </div>
                            </div>
                        }

                        @* Rejection feedback *@
                        @if (!string.IsNullOrEmpty(app.RejectionFeedback) && (app.Status ?? "").IndexOf("reject", StringComparison.OrdinalIgnoreCase) >= 0)
                        {
                            <div style="margin-top:12px; background:var(--red-pale); border-left:4px solid var(--red); padding:12px; border-radius:8px;">
                                <div style="font-weight:700; color:var(--red); margin-bottom:6px;"><i class="fa-solid fa-comment-dots"></i> Employer Feedback</div>
                                <div style="color:var(--text-primary); font-size:13px;">@app.RejectionFeedback</div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* small view-specific adjustments; core theme lives in Content/HireHub.DarkBlue.css */
    .hh-page-header h1 {
        margin: 0;
        font-size: 22px;
    }

    .subtitle {
        margin-top: 6px;
        color: var(--text-muted);
    }

    .app-row:hover {
        transform: translateY(-6px);
        box-shadow: 0 14px 30px rgba(2,33,71,0.05);
    }

    /* Mobile stack */
    @@media (max-width:800px) {
        .app-row {
            flex-direction: column;
            align-items: stretch;
        }

            .app-row > div[style*="text-align:right"] {
                align-items: flex-start;
                text-align: left;
            }

            .app-row .hh-btn {
                width: 100%;
                justify-content: center;
            }
    }
</style>

@section scripts {
    <script>
        (function ($) {
            function showToast(message, type) {
                var $t = $('<div class="hh-alert" style="position:fixed; top:90px; right:18px; z-index:1400;"></div>');
                $t.addClass(type === 'error' ? 'hh-alert-danger' : 'hh-alert-success');
                $t.html('<i class="fa-solid fa-circle-info"></i><div style="margin-left:8px;">' + message + '</div>');
                $('body').append($t);
                setTimeout(function () { $t.fadeOut(300, function () { $t.remove(); }); }, 2200);
            }

            // Withdraw via AJAX with progressive fallback
            $(document).on('click', '.btn-withdraw', function () {
                var id = $(this).data('id');
                if (!id) return;
                if (!confirm('Withdraw this application? You can re-apply later.')) return;

                var $btn = $(this);
                $btn.prop('disabled', true);

                $.post('@Url.Action("Withdraw","Application")', { id: id })
                    .done(function (res) {
                        try {
                            var payload = (typeof res === 'object') ? res : JSON.parse(res || '{}');
                            if (payload && payload.success) {
                                $('.app-row[data-app-id="' + id + '"]').slideUp(180, function () { $(this).remove(); });
                                showToast('Application withdrawn', 'success');
                                return;
                            }
                        } catch (e) { /* ignore */ }

                        // fallback: reload page
                        location.reload();
                    })
                    .fail(function () {
                        showToast('Could not withdraw application. Try again.', 'error');
                        $btn.prop('disabled', false);
                    });
            });
        })(jQuery);
    </script>
}