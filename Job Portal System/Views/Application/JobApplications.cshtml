@model IEnumerable<Job_Portal_System.APPLICATION>

@{
    ViewBag.Title = "Applications";
    Layout = "~/Views/Shared/_EmployeerDashboard.cshtml";
}

<style>
    .page-header {
        text-align: center;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 600;
            color: #002E7F;
            margin-bottom: 4px;
        }

        .page-header p {
            color: #6b7280;
            font-size: 14px;
        }

    .table-card {
        max-width: 1100px;
        margin: 0 auto;
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
        overflow: hidden;
    }

        .table-card table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .table-card thead th {
            background: #f8faff;
            color: #002E7F;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 13px 16px;
            border-bottom: 1px solid #e8edf5;
            text-align: left;
        }

        .table-card tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid #f0f4fa;
            vertical-align: middle;
            font-size: 14px;
            color: #1f2937;
        }

        .table-card tbody tr:last-child td {
            border-bottom: none;
        }

        .table-card tbody tr:hover {
            background: #f8fbff;
        }

    .seeker-name {
        font-weight: 600;
        font-size: 14px;
        color: #111827;
    }

    .seeker-bio {
        font-size: 12px;
        color: #6b7280;
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 160px;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }

    .status-approved {
        background: #dcfce7;
        color: #15803d;
    }

    .status-rejected {
        background: #fee2e2;
        color: #b91c1c;
    }

    .status-pending {
        background: #fef3c7;
        color: #b45309;
    }

    .status-scheduled {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .resume-box {
        width: 48px;
        height: 58px;
        background: #f1f5fb;
        border: 1px solid #d1ddf0;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        color: #6b7280;
        font-weight: 600;
        cursor: pointer;
    }

    .actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: opacity .15s;
    }

        .btn-action:hover {
            opacity: .85;
        }

    .btn-approve {
        background: #dcfce7;
        color: #15803d;
    }

    .btn-reject {
        background: #fee2e2;
        color: #b91c1c;
    }

    .btn-schedule {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .btn-message {
        background: #ede9fe;
        color: #6d28d9;
    }

    /* Modal */
    .modal-content {
        border-radius: 14px;
        border: none;
    }

    .modal-header {
        background: #f8faff;
        border-bottom: 1px solid #e8edf5;
        border-radius: 14px 14px 0 0;
        padding: 16px 20px;
    }

        .modal-header h5 {
            font-size: 16px;
            font-weight: 700;
            color: #002E7F;
            margin: 0;
        }

    .modal-body {
        padding: 20px;
    }

    .modal-footer {
        border-top: 1px solid #e8edf5;
        padding: 14px 20px;
    }

    .form-group label {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 5px;
        display: block;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #d1d5db;
        font-size: 14px;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #9ca3af;
        font-size: 15px;
    }
</style>

<div class="page-header">
    <h2>Applications for: @ViewBag.JobTitle</h2>
    <p>@Model.Count() applicant(s) found</p>
</div>

@if (!Model.Any())
{
    <div class="table-card">
        <div class="empty-state">No applicants yet.</div>
    </div>
}
else
{
    <div class="table-card">
        <table>
            <colgroup>
                <col style="width:20%">
                <col style="width:9%">
                <col style="width:16%">
                <col style="width:12%">
                <col style="width:43%">
            </colgroup>
            <thead>
                <tr>
                    <th>Applicant</th>
                    <th>Resume</th>
                    <th>Status</th>
                    <th>Applied</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model)
                {
                    string statusClass = "status-pending";
                    string s = (app.status ?? "").ToLower();
                    if (s == "approved") { statusClass = "status-approved"; }
                    else if (s == "rejected") { statusClass = "status-rejected"; }
                    else if (s == "interview scheduled") { statusClass = "status-scheduled"; }

                    <tr>
                        <td>
                            <div class="seeker-name">@app.JOB_SEEKER_PROFILE.USER.full_name</div>
                            <div class="seeker-bio" title="@app.JOB_SEEKER_PROFILE.Bio">@app.JOB_SEEKER_PROFILE.Bio</div>
                        </td>

                        <td>
                            @if (!string.IsNullOrEmpty(app.JOB_SEEKER_PROFILE.resume_file))
                            {
                                <a href="@Url.Action("DownloadResume", "Employeer", new { seekerId = app.seeker_id })"
                                   class="resume-box" target="_blank" title="View Resume">PDF</a>
                            }
                            else
                            {
                                <div class="resume-box" style="cursor:default;">—</div>
                            }
                        </td>

                        <td>
                            <span class="status-badge @statusClass">@app.status</span>
                        </td>

                        <td style="color:#6b7280;font-size:13px;">
                            @(app.applied_date.HasValue ? app.applied_date.Value.ToString("dd MMM yyyy") : "--")
                        </td>

                        <td>
                            <div class="actions">
                                <a href="@Url.Action("UpdateStatus", "Application", new { id = app.application_id, status = "APPROVED" })"
                                   class="btn-action btn-approve">✓ Approve</a>

                                <button class="btn-action btn-reject"
                                        onclick="rejectApplication(@app.application_id)">
                                    ✕ Reject
                                </button>

                                <button class="btn-action btn-schedule"
                                        onclick="openScheduleModal(@app.application_id, '@app.JOB_SEEKER_PROFILE.USER.full_name')">
                                    ⊕ Schedule
                                </button>

                                <a href="@Url.Action("Index", "Chat", new { receiverId = app.seeker_id })"
                                   class="btn-action btn-message">✉ Message</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- ===== SCHEDULE MODAL ===== -->
<div class="modal fade" id="scheduleModal" tabindex="-1" role="dialog" aria-labelledby="scheduleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="scheduleModalLabel">
                    Schedule Interview — <span id="modalSeekerName"></span>
                </h5>
                <button type="button" class="close" onclick="$('#scheduleModal').modal('hide')" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="modalAppId" />

                <div class="form-row">
                    <div class="form-group">
                        <label>Interview Type</label>
                        <select id="intType" class="form-control">
                            <option>Online</option>
                            <option>In-Person</option>
                            <option>Phone Call</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Interview Status</label>
                        <select id="intStatus" class="form-control">
                            <option>Scheduled</option>
                            <option>Rescheduled</option>
                            <option>Cancelled</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Date &amp; Time</label>
                    <input type="datetime-local" id="intDate" class="form-control" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Interviewer Name</label>
                        <input type="text" id="intInterviewer" class="form-control" placeholder="Full name" />
                    </div>
                    <div class="form-group">
                        <label>Interviewer Email</label>
                        <input type="email" id="intEmail" class="form-control" placeholder="email@company.com" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Location / Meeting Link</label>
                    <input type="text" id="intLocation" class="form-control" placeholder="e.g. Zoom link or office address" />
                </div>

                <div class="form-group">
                    <label>Instructions for Applicant</label>
                    <textarea id="intNotes" class="form-control" rows="2" placeholder="What should the candidate bring or prepare?"></textarea>
                </div>

                <div class="form-group">
                    <label>Internal Notes</label>
                    <textarea id="internalNotes" class="form-control" rows="2" placeholder="Private notes (not visible to applicant)"></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="$('#scheduleModal').modal('hide')" >Cancel</button>
                <button type="button" class="btn btn-primary" id="saveInterviewBtn">Save Interview</button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        (function ($) {
            // Reject
            window.rejectApplication = function (appId) {
                var reason = prompt("Enter rejection reason (optional):");
                if (reason === null) return;

                $.post('@Url.Action("RejectApplication", "Employeer")', { id: appId, feedback: reason }, function (res) {
                    if (res && res.success) {
                        alert("Application rejected.");
                        location.reload();
                    } else {
                        alert("Error: " + (res && res.message ? res.message : "Unknown"));
                    }
                }).fail(function () {
                    alert("Server error while rejecting application.");
                });
            };

            // Open modal
            window.openScheduleModal = function (appId, seekerName) {
                $('#modalAppId').val(appId);
                $('#modalSeekerName').text(seekerName);

                // Reset fields
                $('#intType').val('Online');
                $('#intDate').val('');
                $('#intLocation').val('');
                $('#intInterviewer').val('');
                $('#intEmail').val('');
                $('#intNotes').val('');
                $('#internalNotes').val('');
                $('#intStatus').val('Scheduled');

                // Fetch existing interview if any
                $.get('@Url.Action("GetInterview", "Employeer")', { appId: appId })
                    .done(function (data) {
                        if (data) {
                            $('#intType').val(data.interview_type || 'Online');
                            $('#intLocation').val(data.location_or_link || '');
                            $('#intInterviewer').val(data.interviewer_name || '');
                            $('#intEmail').val(data.interviewer_email || '');
                            $('#intNotes').val(data.notes_for_seeker || '');
                            $('#internalNotes').val(data.internal_notes || '');
                            $('#intStatus').val(data.interview_status || 'Scheduled');

                            if (data.interview_date) {
                                // Handle both ISO string or /Date(...) JSON.NET formats
                                var dt = null;
                                if (typeof data.interview_date === 'string' && data.interview_date.indexOf('/Date(') === 0) {
                                    var ms = parseInt(data.interview_date.replace(/\/Date\((\d+)\)\//, '$1'));
                                    dt = new Date(ms);
                                } else {
                                    dt = new Date(data.interview_date);
                                }
                                if (!isNaN(dt)) {
                                    var pad = function (n) { return ("0" + n).slice(-2); };
                                    $('#intDate').val(
                                        dt.getFullYear() + "-" + pad(dt.getMonth() + 1) + "-" + pad(dt.getDate()) +
                                        "T" + pad(dt.getHours()) + ":" + pad(dt.getMinutes())
                                    );
                                }
                            }
                        }
                    })
                    .fail(function () {
                        // ignore fetch error but still show modal
                        console.warn('Could not load existing interview details.');
                    })
                    .always(function () {
                        // Show modal after attempt to fetch - ensures bootstrap and jQuery are loaded
                        //$('#scheduleModal').modal({ backdrop: 'static', keyboard: false });
                        $('#scheduleModal').modal('show');
                    });
            };

            // Submit schedule
            function submitSchedule() {
                var dateVal = $('#intDate').val();
                var appId = $('#modalAppId').val();

                if (!dateVal) { alert("Please select a date and time."); return; }
                if (!appId) { alert("Error: Application ID missing."); return; }

                var payload = {
                    appId: appId,
                    type: $('#intType').val(),
                    date: dateVal,
                    location: $('#intLocation').val(),
                    interviewer: $('#intInterviewer').val(),
                    email: $('#intEmail').val(),
                    notes: $('#intNotes').val(),
                    internalNotes: $('#internalNotes').val(),
                    status: $('#intStatus').val()
                };

                $('#saveInterviewBtn').prop('disabled', true);
                $.post('@Url.Action("ScheduleInterview", "Employeer")', payload)
                    .done(function (res) {
                        if (res && res.success) {
                            $('#scheduleModal').modal('hide');
                            alert("Interview saved successfully.");
                            location.reload();
                        } else {
                            alert("Error: " + (res && res.message ? res.message : 'Unable to save interview.'));
                        }
                    })
                    .fail(function (xhr) {
                        console.error(xhr.responseText);
                        alert("A server error occurred. Check console for details.");
                    })
                    .always(function () {
                        $('#saveInterviewBtn').prop('disabled', false);
                    });
            }

            // Wire submit button (use delegated binding in case of partial updates)
            $(document).on('click', '#saveInterviewBtn', submitSchedule);

            // Expose submitSchedule to global in case other code calls it
            window.submitSchedule = submitSchedule;
        })(jQuery);
    </script>
}