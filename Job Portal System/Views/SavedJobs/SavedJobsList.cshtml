@model IEnumerable<Job_Portal_System.ViewModel.SavedJobViewModel>

@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
    var jobs = Model ?? Enumerable.Empty<Job_Portal_System.ViewModel.SavedJobViewModel>();
}

<div class="hh-card" style="max-width:980px; margin:18px auto; padding:18px;">
    <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
        <div>
            <h1 style="margin:0;">Saved Jobs</h1>
            <p class="subtitle" style="margin-top:6px;">Your bookmarked jobs — keep notes, apply, or remove saved listings.</p>
            <div style="color:var(--text-muted); font-size:13px; margin-top:6px;">
                Showing @jobs.Count() saved job(s)
            </div>
        </div>

        <div style="display:flex; gap:8px; align-items:center;">
            <a href="@Url.Action("SavedJobsList","SavedJobs")" class="hh-btn hh-btn-outline hh-btn-sm"><i class="fa-solid fa-sync"></i> Refresh</a>
        </div>
    </div>

    <div style="margin-top:12px; display:grid; gap:12px;">
        @if (!jobs.Any())
        {
            <div class="hh-empty" style="padding:36px;">
                <div class="hh-empty-icon"><i class="fa-solid fa-bookmark"></i></div>
                <h3>No saved jobs</h3>
                <p class="subtitle">Save interesting jobs and they'll appear here for quick access.</p>
            </div>
        }
        else
        {
            foreach (var j in jobs)
            {
                var expired = j.Deadline.HasValue && j.Deadline.Value < DateTime.Now;
                <div class="hh-card saved-job-row" data-jobid="@j.JobID" style="display:flex; gap:14px; align-items:flex-start; padding:14px;">
                    <div style="width:64px; height:64px; border-radius:12px; background:linear-gradient(135deg,var(--blue-light),var(--blue)); color:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:20px;">
                        <i class="fa-solid fa-briefcase"></i>
                    </div>

                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">
                            <div style="min-width:0;">
                                <div style="font-weight:700; color:var(--text-primary); font-size:16px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    @j.JobTitle
                                </div>
                                <div style="color:var(--text-muted); font-size:13px; margin-top:6px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    @j.CompanyName &nbsp;·&nbsp; @j.Location
                                </div>

                                <div style="margin-top:8px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                                    <span class="hh-badge @(expired ? "hh-badge-red" : "hh-badge-blue")" style="font-weight:700;">
                                        @(expired ? "Expired" : "Saved")
                                    </span>

                                    @if (j.Deadline.HasValue)
                                    {
                                        <div style="font-size:13px; color:var(--text-muted);">Deadline: @j.Deadline.Value.ToString("dd MMM yyyy")</div>
                                    }

                                    <div style="font-size:13px; color:var(--text-muted);">Saved: @j.SavedAt.ToString("dd MMM yyyy")</div>
                                </div>
                            </div>

                            <div style="text-align:right; display:flex; flex-direction:column; gap:8px; align-items:flex-end;">
                                <div style="display:flex; gap:8px;">
                                    <a href="@Url.Action("JobDetails","Job", new { id = j.JobID })" class="hh-btn hh-btn-outline hh-btn-sm" title="View job">
                                        <i class="fa-solid fa-eye"></i> View
                                    </a>

                                    <a href="/Job/Apply/@j.JobID" class="hh-btn hh-btn-primary hh-btn-sm" title="Apply for job">
                                        <i class="fa-solid fa-paper-plane"></i> Apply
                                    </a>

                                    <button type="button" class="hh-btn hh-btn-danger hh-btn-sm btn-remove-saved" data-jobid="@j.JobID" title="Remove saved job">
                                        <i class="fa-solid fa-trash"></i> Remove
                                    </button>
                                </div>

                                <div style="width:100%; display:flex; gap:8px; align-items:center;">
                                    <textarea class="saved-notes hh-textarea" data-jobid="@j.JobID" placeholder="Personal notes (e.g. why you saved this, follow-up steps)">@j.Notes</textarea>
                                    <button type="button" class="hh-btn hh-btn-primary hh-btn-sm btn-save-notes" data-jobid="@j.JobID" style="white-space:nowrap;">
                                        <i class="fa-solid fa-floppy-disk"></i> Save Note
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* View-specific adjustments; core theme in Content/HireHub.DarkBlue.css */
    .saved-notes { min-height:44px; resize:vertical; padding:8px 10px; border-radius:8px; border:1px solid var(--border); background:var(--surface); color:var(--text-primary); width:100%; }
    .saved-job-row { transition: transform .12s ease, box-shadow .12s ease; }
    .saved-job-row:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(2,33,71,0.04); }
    .btn-remove-saved i, .btn-save-notes i { margin-right:6px; }

    @@media (max-width:840px) {
        .saved-job-row { flex-direction:column; align-items:stretch; }
        .saved-job-row > div[style*="text-align:right"] { align-items:flex-start; text-align:left; }
        .saved-job-row .saved-notes { width:100%; }
        .saved-job-row .btn-save-notes { width:100%; }
    }
</style>

@section scripts {
    <script>
        (function ($) {
            function toast(message, type) {
                var $t = $('<div class="hh-alert" style="position:fixed; top:90px; right:18px; z-index:1400;"></div>');
                $t.addClass(type === 'error' ? 'hh-alert-danger' : 'hh-alert-success');
                $t.html('<i class="fa-solid fa-circle-info"></i><div style="margin-left:8px;">' + message + '</div>');
                $('body').append($t);
                setTimeout(function () { $t.fadeOut(300, function () { $t.remove(); }); }, 2200);
            }

            // Save notes (AJAX)
            $(document).on('click', '.btn-save-notes', function () {
                var id = $(this).data('jobid');
                var $textarea = $('.saved-notes[data-jobid="' + id + '"]');
                var notes = $textarea.val();
                var $btn = $(this);
                $btn.prop('disabled', true);

                $.post('@Url.Action("UpdateNotes","SavedJobs")', { id: id, notes: notes })
                    .done(function (res) {
                        if (res && res.success) {
                            toast('Notes saved', 'success');
                        } else {
                            toast((res && res.message) || 'Could not save notes', 'error');
                        }
                    })
                    .fail(function () {
                        toast('Server error. Try again.', 'error');
                    })
                    .always(function () {
                        $btn.prop('disabled', false);
                    });
            });

            // Remove saved (AJAX with fallback)
            $(document).on('click', '.btn-remove-saved', function () {
                var jobId = $(this).data('jobid');
                if (!confirm('Remove this job from your saved list?')) return;

                var $row = $('.saved-job-row[data-jobid="' + jobId + '"]');

                $.get('/SavedJobs/RemoveSavedJob', { jobId: jobId })
                    .done(function () {
                        $row.slideUp(180, function () { $(this).remove(); });
                        toast('Removed from saved jobs', 'success');
                    })
                    .fail(function () {
                        // fallback: navigate to the RemoveSavedJob page
                        window.location = '/SavedJobs/RemoveSavedJob?jobId=' + jobId;
                    });
            });
        })(jQuery);
    </script>
}